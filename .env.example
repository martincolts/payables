# Shared environment — read by docker-compose (Postgres) and the backend.
# Copy to .env and adjust. Keep the POSTGRES_* values and DATABASE_URL in sync.

# --- Postgres (consumed by docker-compose.yaml) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=payables
POSTGRES_PORT=5432

# --- Backend (apps/backend) ---
NODE_ENV=development
PORT=8080
# Built from the POSTGRES_* values above (host is localhost since the port is published)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/payables
JWT_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:5173

# --- Tailscale Funnel (consumed by docker-compose.yaml; full-Docker deploy only) ---
# Gives a STABLE public HTTPS URL that survives restarts:
#   https://${TS_HOSTNAME}.<your-tailnet>.ts.net
# TS_AUTHKEY: reusable auth key from the Tailscale admin console
#   (https://login.tailscale.com/admin/settings/keys). Keep it OUT of git.
# TS_HOSTNAME: device name → first label of the public URL.
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx
TS_HOSTNAME=payables
