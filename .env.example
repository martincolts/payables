# Shared environment — read by docker-compose (Postgres) and the backend.
# Copy to .env and adjust. Keep the POSTGRES_* values and DATABASE_URL in sync.

# --- Postgres (consumed by docker-compose.yaml) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=payables
POSTGRES_PORT=5432

# --- Backend (apps/backend) ---
NODE_ENV=development
PORT=8080
# Built from the POSTGRES_* values above (host is localhost since the port is published)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/payables
JWT_SECRET=change-me-in-production
CORS_ORIGIN=http://localhost:5173
